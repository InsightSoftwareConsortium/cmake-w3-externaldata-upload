{
  "name": "cmake-w3-externaldata-upload",
  "version": "4.0.0",
  "scripts": {
    "dev": "concurrently -n \"worker,vite\" -k \"pnpm dev:worker\" \"pnpm dev:frontend\"",
    "dev:frontend": "vite dev",
    "dev:worker": "cd worker && pnpm dev",
    "build": "BASE_DIR=/ vite build",
    "preview": "vite preview --port 4173",
    "worker:deploy": "cd worker && pnpm deploy",
    "worker:db:init": "cd worker && pnpm db:init",
    "worker:db:init:remote": "cd worker && pnpm db:init:remote",
    "worker:install": "cd worker && pnpm install"
  },
  "dependencies": {
    "@storacha/client": "^2.0.7"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "vite": "^7.3.1"
  }
}
